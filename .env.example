# Touchstone Affiliate+ Backend
DATABASE_URL="postgresql://touchstone:touchstone_secret@localhost:5432/touchstone_affiliate"
REDIS_URL="redis://localhost:6379"

# JWT Secrets (generate with: openssl rand -base64 64)
JWT_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_64"
JWT_REFRESH_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_64"

# AI Provider (Gemini via proxy - NEVER expose to frontend)
GEMINI_API_KEY="your-gemini-api-key-here"

# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# CORS - only allow your frontend
CORS_ORIGIN="http://localhost:3000"

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# App
APP_NAME="Touchstone Affiliate+"
